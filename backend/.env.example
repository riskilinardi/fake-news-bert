# Copy to .env and edit. Values shown are the defaults.

# HuggingFace Hub id or local path to the fine-tuned model.
# Swap to your-username/bert-politifact-fakenews once training is done.
MODEL_NAME=riskilinardi/bert-politifact

# Comma-separated list of origins allowed to call the API.
# In production, set this to your Vercel URL only.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Per-IP rate limits.
RATE_LIMIT_PREDICT=30/minute
RATE_LIMIT_EXPLAIN=10/minute
